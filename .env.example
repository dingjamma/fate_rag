# ── AWS General ──────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
AWS_PROFILE=default

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Region where Bedrock models are available (may differ from general region)
BEDROCK_REGION=us-west-2

# Claude model for generation
BEDROCK_MODEL_ID=claude-sonnet-4-20250514

# Titan Embeddings v1 (1536 dimensions)
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1

# ── OpenSearch ────────────────────────────────────────────────────────────────
# For local development with docker-compose:
# OPENSEARCH_ENDPOINT=http://localhost:9200

# For AWS OpenSearch Serverless (set USE_AWS_AUTH=true):
OPENSEARCH_ENDPOINT=https://d1rlyw3wjkz7p0g4svrg.us-west-2.aoss.amazonaws.com

OPENSEARCH_INDEX=fate-lore

# Local docker-compose credentials (not used with USE_AWS_AUTH=true)
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# Set to 'true' when using AWS OpenSearch Serverless (SigV4 auth)
USE_AWS_AUTH=true

# ── Application ───────────────────────────────────────────────────────────────
MAX_TOKENS=2048
TEMPERATURE=0.7

# ── Data pipeline ─────────────────────────────────────────────────────────────
# Directory for raw scraped data (relative to project root)
RAW_DATA_DIR=data/raw

# Directory for chunked data
CHUNKS_DATA_DIR=data/chunks
